# ── Provider: "gemini" (FREE) or "claude" (paid) ─────────────────
LLM_PROVIDER=gemini

# ── Gemini (FREE — 1500 req/day free tier) ───────────────────────
# Get your free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Anthropic Claude (optional, paid) ────────────────────────────
# Get your key at: https://console.anthropic.com
#ANTHROPIC_API_KEY=your_anthropic_api_key_here
#CLAUDE_MODEL=claude-haiku-4-5-20251001

# ── LinkedIn App Credentials ──────────────────────────────────────
# Get these from https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_REDIRECT_URI=http://localhost:8080/callback

# ── LinkedIn Tokens (auto-populated by oauth_setup.py) ────────────
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_REFRESH_TOKEN=
LINKEDIN_TOKEN_EXPIRES_AT=
LINKEDIN_REFRESH_ISSUED_AT=
LINKEDIN_PERSON_URN=

# ── Behaviour ─────────────────────────────────────────────────────
# Set DRY_RUN=true to generate content without posting to LinkedIn
DRY_RUN=false
POST_HOUR=8
POST_MINUTE=30

# ── v2: Image Generation (Remotion) ──────────────────────────────
# Set ENABLE_IMAGES=false to skip image generation and post text-only
ENABLE_IMAGES=true
# Directory where generated post image PNGs are saved (relative to project root)
IMAGE_OUTPUT_DIR=images
