# ── Provider: "openrouter" (FREE, default), "gemini" (FREE fallback), or "claude" (paid)
LLM_PROVIDER=openrouter

# ── OpenRouter (FREE — 200+ free models, no billing) ─────────────────────────
# Get your free key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=meta-llama/llama-4-maverick:free

# ── Gemini (FREE fallback — 1500 req/day text-only) ──────────────────────────
# Only used if OPENROUTER_API_KEY is blank or LLM_PROVIDER=gemini
# Get your free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Anthropic Claude (optional, paid) ────────────────────────────────────────
# Get your key at: https://console.anthropic.com
#ANTHROPIC_API_KEY=your_anthropic_api_key_here
#CLAUDE_MODEL=claude-haiku-4-5-20251001

# ── HuggingFace (FREE — image generation fallback for AI images) ──────────────
# Get free token at: https://huggingface.co/settings/tokens (read scope only)
HF_TOKEN=your_hf_token_here

# ── LinkedIn App Credentials ──────────────────────────────────────────────────
# Get these from https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_REDIRECT_URI=http://localhost:8080/callback
LINKEDIN_HANDLE=your_linkedin_handle  # shown in branding overlay on AI images

# ── LinkedIn Tokens (auto-populated by oauth_setup.py) ────────────────────────
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_REFRESH_TOKEN=
LINKEDIN_TOKEN_EXPIRES_AT=
LINKEDIN_REFRESH_ISSUED_AT=
LINKEDIN_PERSON_URN=

# ── Behaviour ─────────────────────────────────────────────────────────────────
DRY_RUN=false
POST_HOUR=8
POST_MINUTE=30

# ── v3: Image Generation ──────────────────────────────────────────────────────
ENABLE_IMAGES=true
# Set ENABLE_AI_IMAGES=true to generate contextual AI images instead of Remotion cards
# Pipeline: OpenRouter image API → HF FLUX.1-schnell → Remotion card (fallback)
ENABLE_AI_IMAGES=false
IMAGE_OUTPUT_DIR=images
